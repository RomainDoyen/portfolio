---
import { footerLinks } from '../../data/footer';
---

<footer class="w-full py-16 bg-background border-t border-outline-variant/30" role="contentinfo">
	<div
		class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop flex flex-col md:flex-row justify-between items-center gap-gutter"
	>
		<div class="font-display text-headline-md text-primary font-bold">Romain Doyen</div>
		<p class="font-mono text-label-mono text-on-surface-variant text-center md:text-left">
			© {new Date().getFullYear()} Romain Doyen. Tous droits réservés.
		</p>
		<div class="flex gap-6">
			{
				footerLinks.map((link) => (
					<a
						href={link.href}
						target="_blank"
						rel="noopener noreferrer"
						class="font-mono text-label-mono text-on-surface-variant hover:text-primary transition-colors"
					>
						{link.label}
					</a>
				))
			}
		</div>
	</div>
</footer>
