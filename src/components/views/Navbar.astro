---
const links = [
	{ href: '#accueil', label: 'Accueil', active: true },
	{ href: '#propos', label: 'À propos' },
	{ href: '#experiences', label: 'Mes expériences' },
	{ href: '#projets', label: 'Mes projets' },
];
---

<nav
	aria-label="Navigation principale"
	class="fixed top-0 w-full z-50 bg-surface/60 backdrop-blur-md border-b border-white/10 shadow-[0_0_15px_rgba(245,166,35,0.05)]"
>
	<div
		class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop flex justify-between items-center h-20"
	>
		<a
			href="#accueil"
			class="font-display text-lg sm:text-xl lg:text-2xl font-bold text-primary shrink-0"
		>
			Romain Doyen
		</a>

		<div class="hidden lg:flex gap-4 xl:gap-gutter items-center">
			{
				links.map((link) => (
					<a
						href={link.href}
						data-nav-section
						class:list={[
							'font-display text-button transition-colors hover:text-primary hover:drop-shadow-[0_0_8px_rgba(245,166,35,0.8)]',
							link.active ? 'nav-link-active' : 'text-on-surface-variant',
						]}
					>
						{link.label}
					</a>
				))
			}
			<a
				href="#contact"
				class="ml-4 bg-primary-container text-on-primary-container px-6 py-3 rounded-lg font-display text-button hover:brightness-110 transition-all shadow-lg hover:shadow-primary/20"
			>
				Contact
			</a>
		</div>

		<button
			type="button"
			id="mobile-menu-btn"
			class="lg:hidden text-primary p-2"
			aria-label="Ouvrir le menu"
		>
			<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
			</svg>
		</button>
	</div>

	<div id="mobile-menu" class="hidden lg:hidden border-t border-white/10 bg-surface/95 backdrop-blur-md">
		<div class="flex flex-col gap-2 p-4">
			{
				links.map((link) => (
					<a
						href={link.href}
						data-nav-section
						class:list={[
							'font-display text-button py-2',
							link.active ? 'text-primary' : 'text-on-surface-variant',
						]}
					>
						{link.label}
					</a>
				))
			}
			<a href="#contact" class="btn-primary text-center mt-2 py-3">Contact</a>
		</div>
	</div>
</nav>
