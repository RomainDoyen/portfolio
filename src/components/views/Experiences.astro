---
import { Image } from 'astro:assets';
import { experiences } from '../../data/experiences';
---

<section
	class="section-py px-margin-mobile md:px-margin-desktop bg-surface-container-low/30"
	id="experiences"
	aria-labelledby="experiences-heading"
>
	<div class="max-w-container-max mx-auto">
		<h2
			id="experiences-heading"
			class="font-display text-headline-md text-primary mb-16 text-center neon-glow scroll-reveal"
		>
			Parcours professionnel
		</h2>

		<div class="relative max-w-3xl mx-auto pl-8 lg:pl-0">
			<div
				class="absolute left-0 lg:left-1/2 top-0 bottom-0 w-[2px] timeline-line transform lg:-translate-x-1/2"
				aria-hidden="true"
			/>

			{
				experiences.map((exp, index) => {
					const isRight = index % 2 === 1;
					return (
						<div
							class:list={[
								'relative mb-20 scroll-reveal timeline-item-container last:mb-0',
							]}
						>
							<div
								class="timeline-dot absolute left-[-41px] lg:left-1/2 lg:-translate-x-1/2 top-6 w-5 h-5 bg-primary rounded-full shadow-[0_0_15px_#f5a623] z-10 transition-all duration-300"
								aria-hidden="true"
							/>
							<div
								class:list={[
									'lg:w-1/2',
									isRight ? 'lg:ml-auto lg:pl-12' : 'lg:pr-12 lg:text-right',
								]}
							>
								<div class="glass-card p-6 rounded-2xl w-full">
									<div
										class:list={[
											'flex items-center gap-3 mb-4',
											!isRight ? 'lg:justify-end' : '',
										]}
									>
										<Image
											src={exp.image}
											alt={exp.company}
											class="w-10 h-10 rounded-full object-cover shrink-0 ring-2 ring-primary/30"
										/>
										<div class:list={[!isRight && 'lg:text-right']}>
											<span class="font-mono text-label-mono text-primary bg-primary/10 px-3 py-1 rounded-full inline-block">
												{exp.period}
											</span>
										</div>
									</div>
									<h3 class="font-display text-headline-md mb-2 text-xl md:text-2xl">
										{exp.role}
									</h3>
									<p
										class:list={[
											'text-primary mb-4 font-display text-button',
											!isRight && 'lg:text-right',
										]}
									>
										{exp.company}
									</p>
									<p class="text-on-surface-variant mb-4">{exp.description}</p>
									<div
										class:list={[
											'flex flex-wrap gap-2',
											!isRight && 'lg:justify-end',
										]}
									>
										{exp.tags.map((tag) => (
											<span class="chip">{tag}</span>
										))}
									</div>
								</div>
							</div>
						</div>
					);
				})
			}
		</div>
	</div>
</section>
