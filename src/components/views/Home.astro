---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import img from '../../assets/rd.png';
---

<section
	class="min-h-screen flex items-center pt-20 px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto"
	id="accueil"
	aria-label="Accueil"
>
	<div class="grid lg:grid-cols-2 gap-gutter items-center w-full">
		<div class="scroll-reveal min-w-0 text-center lg:text-left">
			<h1
				class="font-display text-display-lg-mobile lg:text-display-lg mb-6 leading-none"
			>
				Développeur <span class="text-primary neon-glow">Fullstack</span> passionné
			</h1>
			<p class="text-body-lg text-on-surface-variant mb-10 max-w-lg mx-auto lg:mx-0">
				Je ne livre pas des maquettes&nbsp;: je livre des produits web et mobile prêts
				à tourner en production.
			</p>
			<div class="flex flex-wrap gap-4 justify-center lg:justify-start">
				<a href="#contact" class="btn-primary">Contactez-moi</a>
				<a href="#projets" class="btn-secondary">Voir mes projets</a>
			</div>
		</div>

		<div
			class="relative flex flex-col items-center scroll-reveal mt-12 lg:mt-0 min-w-0 w-full max-w-[420px] mx-auto lg:max-w-none"
		>
			<div
				class="relative w-full max-w-[288px] sm:max-w-[360px] lg:max-w-[420px] aspect-square glass-card rounded-3xl flex items-center justify-center border border-primary/20 p-8 sm:p-10 lg:p-14"
			>
				<Image
					src={img}
					alt="Romain Doyen — développeur fullstack, logo du portfolio"
					class="w-full h-full object-contain"
				/>
			</div>
			<div
				class="mt-6 lg:mt-0 lg:absolute lg:-bottom-6 lg:-right-2 xl:bottom-0 xl:right-0 glass-card p-4 sm:p-6 rounded-2xl flex items-center gap-4 w-full sm:w-auto"
			>
				<div
					class="w-12 h-12 rounded-full bg-primary/20 flex items-center justify-center text-primary"
				>
					<Icon name="mdi:code-tags" class="w-6 h-6" />
				</div>
				<div>
					<div class="font-mono text-label-mono text-primary">2+ Ans</div>
					<div class="font-display text-button">Expérience</div>
				</div>
			</div>
		</div>
	</div>
</section>
